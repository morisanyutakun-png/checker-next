# ═══════════════════════════════════════════════════════════
# Checker-Next 環境変数
# ═══════════════════════════════════════════════════════════
# cp .env.example .env してから使用してください

# ── PostgreSQL (ローカル開発) ──────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=checker

# ── FastAPI バックエンド ───────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/checker
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@db:5432/checker
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080
STORAGE_DIR=/app/storage
SECRET_KEY=change-me-in-production
DEBUG=true
PORT=8000

# ── Next.js フロントエンド ─────────────────────────────────
# サーバーサイド rewrite 先（Docker 内部 DNS / 本番は Koyeb URL）
API_BASE_URL=http://api:8000
# クライアント側ベース URL（空欄 → Next.js rewrite 経由でプロキシ）
NEXT_PUBLIC_API_BASE_URL=

# ═══════════════════════════════════════════════════════════
# 本番デプロイ設定 (コメント解除して使用)
# ═══════════════════════════════════════════════════════════

# ── Neon (Database) ───────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.us-east-2.aws.neon.tech/checker?sslmode=require
# DATABASE_URL_SYNC=postgresql+psycopg2://user:pass@ep-xxx.us-east-2.aws.neon.tech/checker?sslmode=require

# ── Koyeb (API) ──────────────────────────────────────────
# CORS_ORIGINS=https://your-app.vercel.app
# SECRET_KEY=<ランダムな32文字以上の文字列>
# DEBUG=false

# ── Vercel (Web) ─────────────────────────────────────────
# API_BASE_URL=https://your-api-xxx.koyeb.app
# NEXT_PUBLIC_API_BASE_URL=
